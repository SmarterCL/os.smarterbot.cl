      "typeVersion": 3.4,
      "position": [700, 340]
    },
    {
      "parameters": {
        "content": "={{ `⚙️ Problemas de EGR son muy comunes.\\n\\n*EGR OFF* — Eliminación definitiva:\\n\\n✅ Elimina humo negro\\n✅ Mejora ralentí\\n✅ Mayor vida del motor\\n\\n💰 Precio: $100\\n🕐 Entrega: 24h\\n\\n¿Te interesa?` }}",
        "jsonOutput": true
