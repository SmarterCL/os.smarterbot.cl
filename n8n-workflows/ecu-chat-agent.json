      "typeVersion": 3.4,
      "position": [700, 540]
    },
    {
      "parameters": {
        "content": "={{ `Hola 👋 No estoy seguro de tu consulta específica.\\n\\nNuestros servicios:\\n🏎️ Stage 1 — +20-30% potencia ($150)\\n🔧 DPF OFF — Solución filtro ($120)\\n⚙️ EGR OFF — Eliminación válvula ($100)\\n\\n¿Cuál te interesa?` }}",
        "jsonOutput": true
