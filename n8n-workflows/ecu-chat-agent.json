    {
      "parameters": {
        "content": "={{ `🔧 Entiendo tu problema con el DPF.\\n\\n*DPF OFF* — Solución definitiva:\\n\\n✅ Elimina regeneraciones forzadas\\n✅ Recupera potencia\\n✅ Mejora consumo\\n\\n💰 Precio: $120\\n🕐 Entrega: 24h\\n\\n¿Quieres solucionarlo?` }}",
        "jsonOutput": true
