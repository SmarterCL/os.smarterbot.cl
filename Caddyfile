# ============================================
# SMARTEROS — CADDY CONFIG
# os.smarterbot.store + routes legacy
# ============================================

{
    email smarterbotcl@gmail.com
}

# ------------------------------------------
# DOMINIO PRINCIPAL
# ------------------------------------------
os.smarterbot.store {
    reverse_proxy /api/* localhost:8002
    reverse_proxy /bolt/* localhost:8501
    reverse_proxy /n8n/* localhost:5678
    reverse_proxy /docling/* localhost:8080
    
    encode gzip
    
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# ------------------------------------------
# SUBDOMINIOS
# ------------------------------------------
bolt.smarterbot.store {
    reverse_proxy localhost:8501
    encode gzip
}

docling.smarterbot.store {
    reverse_proxy localhost:8080
    encode gzip
}

n8n.smarterbot.store {
    reverse_proxy localhost:5678
    encode gzip
}

# ------------------------------------------
# REDIRECTS .CL → .STORE
# ------------------------------------------
os.smarterbot.cl {
    redir https://os.smarterbot.store{uri} permanent
}

bolt.smarterbot.cl {
    redir https://bolt.smarterbot.store{uri} permanent
}

