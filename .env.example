# .env.example - SmarterOS Brain Configuration

# Node Environment
NODE_ENV=production

# Database: PostgreSQL
DATABASE_URL=postgresql://smarteros:smarteros@postgres:5432/smarteros
DB_HOST=postgres
DB_PORT=5432
DB_USER=smarteros
DB_PASSWORD=smarteros
DB_NAME=smarteros

# Neo4j Graph Database
NEO4J_URL=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=smarteros

# Redis Cache
REDIS_URL=redis://redis:6379

# API Configuration
API_PORT=3000
API_HOST=0.0.0.0
API_VERSION=v1

# Orchestrator Configuration
ORCHESTRATOR_URL=http://orchestrator:3000
ORCHESTRATOR_PORT=3000

# BioStack Configuration (Market Entropy)
BIOSTACK_PORT=3001
BIOSTACK_URL=http://biostack:3001

# RoutingBrain Configuration (Fee Optimization)
ROUTING_BRAIN_PORT=3002
ROUTING_BRAIN_URL=http://routing-brain:3002

# LedgerBrain Configuration (Accounting)
LEDGER_BRAIN_PORT=3003
LEDGER_BRAIN_URL=http://ledger-brain:3003

# Memory Service (Python ML)
MEMORY_PORT=5000
MEMORY_URL=http://memory:5000

# Payment Processors
STRIPE_API_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=xxx
WEBPAY_API_KEY=xxxxxxxxxxxxx
STP_API_KEY=xxxxxxxxxxxxx

# Fraud Detection
FRAUD_THRESHOLD=0.85
FRAUD_VELOCITY_CHECK=enabled
FRAUD_GEO_CHECK=enabled
FRAUD_AMOUNT_MISMATCH=enabled

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3100
GRAFANA_ADMIN_PASSWORD=smarteros

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DESTINATION=stdout

# Security
JWT_SECRET=your_jwt_secret_here_change_me
API_KEY_MASTER=your_master_api_key_here_change_me
ENCRYPTION_KEY=your_encryption_key_here_change_me

# Domain Configuration
DOMAIN=smarterbot.cl
API_DOMAIN=api.smarterbot.cl
HTTPS_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/smarterbot.cl.crt
SSL_KEY_PATH=/etc/ssl/private/smarterbot.cl.key

# SMS/Email Notifications
SENDGRID_API_KEY=xxxxxxxxxxxxx
TWILIO_ACCOUNT_SID=xxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxx

# Feature Flags
FEATURE_FRAUD_DETECTION=true
FEATURE_SMART_ROUTING=true
FEATURE_AUTO_RECONCILIATION=true
FEATURE_GRAPH_ANALYTICS=true

# Development (set to false in production)
DEBUG=false
VERBOSE_LOGGING=false
